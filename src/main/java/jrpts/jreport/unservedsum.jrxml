	<parameter name="DatedFr" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").parse("2026-01-01", new java.text.ParsePosition(0));]]></defaultValueExpression>
	</parameter>
	<parameter name="DateTo" class="java.util.Date" isForPrompting="false">
		<defaultValueExpression><![CDATA[new java.text.SimpleDateFormat("yyyy-MM-dd").parse("2026-02-28", new java.text.ParsePosition(0));]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT DISTINCT
	offices.office, humane(jobworker.lastname, jobworker.firstname, jobworker.suffix, jobworker.midname) AS ngalan
FROM cbo.jobarrange INNER JOIN psnl.jobworker
	ON jobarrange.empkey = jobworker.uniqkey
	INNER JOIN psnl.offices
	ON jobarrange.offcloc = offices.offcid 
WHERE
	(jobarrange.offcloc <> '1021') AND
	(jobarrange.jobyear = DATE_PART('YEAR', $P{DateTo}::DATE)) AND
	($P{DatedFr}::DATE BETWEEN jobarrange.frdate AND jobarrange.todate) AND
	(NOT EXISTS(SELECT 0 FROM pay.timebook 
				WHERE (worker = jobarrange.empkey) AND 
			   		  (datefr >= $P{DatedFr}::DATE ) AND (dateto <= $P{DateTo}::DATE ) AND
				      (DATE_PART('YEAR', datefr) = DATE_PART('YEAR', $P{DateTo}::DATE))))
ORDER BY offices.office]]>
	</queryString>
